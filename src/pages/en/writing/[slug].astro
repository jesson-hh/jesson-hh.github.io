---
import Base from '../../../layouts/Base.astro';
import PostArticle from '../../../components/PostArticle.astro';
import { getPosts, getSite } from '../../../data/content';
import type { Post } from '../../../data/content';

const lang = 'en' as const;

export function getStaticPaths() {
  return getPosts('en').map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

interface Props { post: Post }
const { post } = Astro.props;
const site = getSite(lang);
---

<Base lang={lang} title={`${post.title} · ${site.name}`} description={post.summary}>
  <PostArticle lang={lang} post={post} />
</Base>
