---
import type { Lang } from '../i18n/ui';
import { useTranslations, localizePath } from '../i18n/ui';
import { getProjects } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const projects = getProjects(lang);
const range = lang === 'zh' ? '2024 — 2026 · 点击进入详情' : '2024 — 2026 · click for detail';
---

<section class="section work" id="work">
  <div class="wrap">
    <div class="rule reveal">
      <span class="label section-index is-accent">01 — {t('sec.work')}</span>
      <span class="meta section-index">{range}</span>
    </div>

    <div class="list">
      {projects.map((p, i) => (
        <a
          class={`item reveal from-left${p.inProgress ? ' is-in-progress' : ''}`}
          style={`--i:${i}`}
          href={localizePath(`/projects/${p.slug}`, lang)}
        >
          <div class="thumb" style={`background-image:url('${p.thumb}')`}></div>
          <div class="body">
            <span class="cat mono">{p.category}</span>
            <h3 class="serif">{p.title}</h3>
            <p>{p.summary}</p>
          </div>
          <span class="go mono">{t('work.enter')} →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .list { /* no top border; .rule already has one */ }
  .item {
    display: grid;
    grid-template-columns: 160px 1fr auto;
    gap: 32px; align-items: center;
    padding: 26px 0;
    border-bottom: 1px solid rgba(216, 180, 106, .10);
    transition: padding .3s var(--ease), background .3s var(--ease);
  }
  .item:hover { padding-left: 14px; }
  .item:first-child { border-top: 1px solid rgba(216, 180, 106, .10); }

  /* small staggers for the first three reveals (per-row delay) */
  .item.reveal:nth-of-type(1) { transition-delay: 0ms; }
  .item.reveal:nth-of-type(2) { transition-delay: 90ms; }
  .item.reveal:nth-of-type(3) { transition-delay: 180ms; }

  .thumb {
    width: 160px; height: 110px;
    border-radius: 8px;
    background-size: cover; background-position: center;
    box-shadow:
      0 12px 32px -16px rgba(0, 0, 0, .6),
      inset 0 0 0 1px rgba(216, 180, 106, .18);
    filter: saturate(1.05);
  }

  .body { min-width: 0; }
  .cat {
    font-size: 11px; letter-spacing: .16em;
    text-transform: uppercase; color: var(--accent-gold);
  }
  .item h3 {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(22px, 2.6vw, 28px);
    line-height: 1.18;
    margin: 8px 0; color: var(--ink-star);
    transition: color .2s var(--ease);
  }
  .item:hover h3 { color: var(--accent-gold); }
  .body p {
    font-size: 14.5px; line-height: 1.65;
    color: var(--ink-soft); max-width: 58ch;
  }
  .go {
    font-size: 12px; color: var(--muted);
    white-space: nowrap;
    transition: color .2s var(--ease);
  }
  .item:hover .go { color: var(--accent-gold); }

  /* "in progress" badge — a small pill next to the category label */
  .is-in-progress .cat::after {
    content: "";
    display: inline-block;
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent-cool);
    box-shadow: 0 0 8px 1px rgba(156, 180, 255, .7);
    margin-left: 10px; vertical-align: middle;
    animation: live-pulse 1.8s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%, 100% { box-shadow: 0 0 8px 1px rgba(156, 180, 255, .55); }
    50%      { box-shadow: 0 0 14px 4px rgba(156, 180, 255, .85); }
  }

  @media (max-width: 760px) {
    .item { grid-template-columns: 1fr; gap: 14px; }
    .item:hover { padding-left: 0; }
    .thumb { width: 100%; height: 200px; }
    .go { display: none; }
  }
</style>
