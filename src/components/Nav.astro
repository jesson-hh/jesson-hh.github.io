---
import type { Lang } from '../i18n/ui';
import { useTranslations, localizePath, alternatePath } from '../i18n/ui';
import { getSite } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const site = getSite(lang);
const home = localizePath('/', lang);
const other: Lang = lang === 'zh' ? 'en' : 'zh';
const altHref = alternatePath(Astro.url, other);

const links = [
  { label: t('nav.work'), href: `${home}#work` },
  { label: t('nav.about'), href: `${home}#about` },
  { label: t('nav.writing'), href: localizePath('/writing', lang) },
];
---

<header class="nav">
  <div class="wrap bar">
    <a class="brand serif" href={home}>{site.name}</a>

    <input type="checkbox" id="navtoggle" class="navtoggle" hidden />
    <label class="burger" for="navtoggle" aria-label="Menu">
      <span></span><span></span>
    </label>

    <nav class="links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a class="lang mono" href={altHref} aria-label="Switch language">{t('lang.switch')}</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: absolute;          /* sits above hero, scrolls away with the page */
    top: 0; left: 0; right: 0;
    z-index: 10;
    padding-top: 46px;
  }
  .bar { display: flex; align-items: center; justify-content: space-between; width: 100%; }
  .brand {
    font-family: var(--serif);
    font-size: 24px;
    letter-spacing: .005em;
    color: var(--ink-star);
    transition: color .2s var(--ease);
  }
  .brand:hover { color: var(--accent-gold); }

  .links { display: flex; align-items: center; gap: 28px; }
  .links a {
    font-size: 13px;
    color: var(--ink-soft);
    transition: color .18s var(--ease);
  }
  .links a:not(.lang):hover { color: var(--accent-gold); }
  .lang {
    font-size: 11px;
    color: var(--accent-gold);
    border: 1px solid rgba(216, 180, 106, .3);
    padding: 5px 10px; border-radius: 6px;
    letter-spacing: .14em;
    transition: background .18s var(--ease), color .18s var(--ease), border-color .18s var(--ease);
  }
  .lang:hover {
    background: rgba(216, 180, 106, .12);
    border-color: rgba(216, 180, 106, .55);
    color: #fff;
  }

  /* mobile burger (CSS-only) */
  .burger {
    display: none;
    width: 28px; height: 22px;
    flex-direction: column; justify-content: center; gap: 6px;
  }
  .burger span {
    display: block; height: 1.5px;
    background: var(--ink-star);
    transition: transform .25s var(--ease), opacity .2s;
  }

  @media (max-width: 760px) {
    .nav { padding-top: 22px; }
    .burger { display: flex; }
    .links {
      position: absolute; top: 56px; left: 0; right: 0;
      flex-direction: column; align-items: flex-start; gap: 4px;
      background: rgba(5, 8, 22, .92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--glass-line);
      padding: 14px var(--pad) 22px;
      max-height: 0; overflow: hidden; opacity: 0;
      transition: max-height .3s var(--ease), opacity .25s, padding .3s var(--ease);
      padding-block: 0;
    }
    .links a { padding: 10px 0; font-size: 16px; }
    .navtoggle:checked ~ .links { max-height: 60vh; opacity: 1; padding-block: 14px 22px; }
    .navtoggle:checked ~ .burger span:first-child { transform: translateY(3.75px) rotate(45deg); }
    .navtoggle:checked ~ .burger span:last-child  { transform: translateY(-3.75px) rotate(-45deg); }
  }
</style>
