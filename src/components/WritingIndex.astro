---
import type { Lang } from '../i18n/ui';
import { useTranslations, localizePath } from '../i18n/ui';
import { getPosts } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const posts = getPosts(lang);
const sub = lang === 'zh' ? '研究笔记 & 技术文章' : 'Research notes & technical writing';
const home = lang === 'zh' ? '返回首页' : 'Back home';
---

<section class="section idx">
  <div class="wrap">
    <a class="back mono reveal" href={localizePath('/', lang)}>← {home}</a>
    <h1 class="serif reveal">{t('sec.writing')}</h1>
    <p class="sub mono reveal">{sub}</p>

    <div class="list reveal">
      {posts.map((p) => (
        <a class="row" href={localizePath(`/writing/${p.slug}`, lang)}>
          <span class="date mono">{p.date}</span>
          <span class="main">
            <span class="title serif">{p.title}</span>
            <span class="sum">{p.summary}</span>
          </span>
          <span class="tag mono">{p.tag} · {p.reading} {t('reading')}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .idx { padding-top: clamp(80px, 9vw, 110px); }

  .back { font-size: 13px; color: var(--muted); }
  .back:hover { color: var(--accent-gold); }

  h1 {
    margin-top: 26px;
    font-family: var(--serif);
    font-weight: 400; font-style: italic;
    font-size: clamp(38px, 6.4vw, 72px); line-height: 1.04; letter-spacing: -.015em;
    color: var(--ink-star);
  }
  .sub { margin-top: 14px; font-size: 12px; color: var(--muted); letter-spacing: .04em; }

  .list {
    margin-top: 44px;
    border-top: 1px solid var(--glass-line);
  }
  .row {
    display: grid;
    grid-template-columns: 130px 1fr auto;
    gap: 26px; align-items: baseline;
    padding: 26px 0;
    border-bottom: 1px solid var(--glass-line);
    transition: padding-left .3s var(--ease);
  }
  .row:hover { padding-left: 12px; }
  .date { font-size: 13px; color: var(--muted); }
  .title {
    display: block;
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(20px, 2.6vw, 26px); line-height: 1.2;
    color: var(--ink-star);
    transition: color .2s var(--ease);
  }
  .row:hover .title { color: var(--accent-gold); }
  .sum {
    display: block;
    margin-top: 8px;
    font-size: 14.5px; line-height: 1.6;
    color: var(--ink-soft);
    max-width: 60ch;
  }
  .tag { font-size: 11px; color: var(--muted); white-space: nowrap; }

  @media (max-width: 680px) {
    .row { grid-template-columns: 1fr; gap: 6px; }
    .row:hover { padding-left: 0; }
    .date { order: -1; }
    .tag { display: none; }
  }
</style>
