---
import type { Lang } from '../i18n/ui';
import { useTranslations, localizePath } from '../i18n/ui';
import { getPosts } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const posts = getPosts(lang);
const more = lang === 'zh' ? '研究笔记 & 技术文章 · 全部 →' : 'Research notes & writing · all →';
---

<section class="section writing" id="writing">
  <div class="wrap">
    <div class="rule reveal">
      <span class="label section-index is-accent">03 — {t('sec.writing')}</span>
      <a class="meta section-index more" href={localizePath('/writing', lang)}>{more}</a>
    </div>

    <div class="list">
      {posts.map((p) => (
        <a class="post reveal from-left" href={localizePath(`/writing/${p.slug}`, lang)}>
          <span class="date mono">{p.date}</span>
          <span class="title serif">{p.title}</span>
          <span class="tag mono">{p.tag} · {p.reading} {t('reading')}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .more { color: var(--muted); transition: color .18s var(--ease); }
  .more:hover { color: var(--accent-gold); }

  .post {
    display: grid;
    grid-template-columns: 130px 1fr auto;
    gap: 24px; align-items: baseline;
    padding: 22px 0;
    border-bottom: 1px solid rgba(216, 180, 106, .10);
    transition: padding .3s var(--ease);
  }
  .post:first-child { border-top: 1px solid rgba(216, 180, 106, .10); }
  .post:hover { padding-left: 10px; }
  .post.reveal:nth-of-type(2) { transition-delay: 90ms; }
  .post.reveal:nth-of-type(3) { transition-delay: 180ms; }

  .date { font-size: 12px; color: var(--muted); }
  .title {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(18px, 2.2vw, 22px); line-height: 1.3;
    color: var(--ink-star);
    transition: color .2s var(--ease);
  }
  .post:hover .title { color: var(--accent-gold); }
  .tag { font-size: 11px; color: var(--muted); white-space: nowrap; }

  @media (max-width: 760px) {
    .post { grid-template-columns: 1fr; gap: 5px; }
    .post:hover { padding-left: 0; }
    .date { order: -1; }
    .tag { display: none; }
  }
</style>
